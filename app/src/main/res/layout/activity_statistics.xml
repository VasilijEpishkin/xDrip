<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/stats_main_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/md_background"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/md_background" />

        <!-- Period selector row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/stats_time_period_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stats time period label"
                    android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                    android:textColor="@color/md_on_surface_variant"
                    android:paddingBottom="4dp" />

                <LinearLayout
                    android:id="@+id/stats_buttons_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_stats_today"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TD"
                        android:textAllCaps="false"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:layout_marginEnd="4dp"
                        android:textSize="13sp"
                        app:cornerRadius="20dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_stats_yesterday"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="YTD"
                        android:textAllCaps="false"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:layout_marginEnd="4dp"
                        android:textSize="13sp"
                        app:cornerRadius="20dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_stats_7d"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7d"
                        android:textAllCaps="false"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:layout_marginEnd="4dp"
                        android:textSize="13sp"
                        app:cornerRadius="20dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_stats_30d"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="30d"
                        android:textAllCaps="false"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:layout_marginEnd="4dp"
                        android:textSize="13sp"
                        app:cornerRadius="20dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_stats_90d"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="90d"
                        android:textAllCaps="false"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:textSize="13sp"
                        app:cornerRadius="20dp" />
                </LinearLayout>
            </LinearLayout>

            <ImageButton
                android:id="@+id/imageButton3"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_fullscreen_exit_grey600_24dp"
                android:background="@android:color/transparent"
                android:onClick="statisticsDisableFullScreen"
                android:tint="@color/md_on_surface_variant" />

            <ImageButton
                android:id="@+id/imageButton4"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_share_variant_grey600_24dp"
                android:background="@android:color/transparent"
                android:onClick="statisticsShare"
                android:tint="@color/md_on_surface_variant" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/indicator_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="horizontal" />

        <androidx.viewpager.widget.ViewPager
            android:id="@+id/pager"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/md_background" />

    </LinearLayout>

    <fragment
        android:id="@+id/navigation_drawer"
        android:name="com.eveningoutpost.dexdrip.NavigationDrawerFragment"
        android:layout_width="@dimen/navigation_drawer_width"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        tools:layout="@layout/fragment_navigation_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>
